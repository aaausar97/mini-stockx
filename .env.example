# Copy this file to .env and fill in your values
# Never commit .env to git

# AWS credentials
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1

# Create these in AWS Console:
# 1. SNS Topic → copy ARN here
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:stockx-order-matched

# 2. SQS Queue for payment service → subscribe it to the SNS topic above
SQS_PAYMENT_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/stockx-payment

# 3. SQS Queue for notification service → subscribe it to the SNS topic above
SQS_NOTIFY_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/stockx-notify
